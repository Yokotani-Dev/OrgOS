# OrgOS Intelligence source configuration.
# Source URLs are data, not code: update this file instead of hardcoding feeds
# into the collector.

pipeline:
  default_fetch_cadence: weekly
  default_cache_ttl: 24h
  rate_limit: 1 req/source/day
  output:
    raw_dir: .ai/INTELLIGENCE/raw
    weekly_dir: .ai/INTELLIGENCE/weekly
    reports_dir: .ai/INTELLIGENCE/reports

watch_topics:
  - AI agents / agentic patterns
  - multi-agent systems
  - agent evaluation / benchmarks
  - Claude Code / Claude API changes
  - MCP (Model Context Protocol)
  - Anthropic SDK updates
  - prompt engineering
  - LLM evaluation / evals
  - coding assistants
  - AI safety / alignment
  - AI-driven development
  - AI code review
  - AI testing

sources:
  - id: anthropic-news
    name: Anthropic News
    type: rss
    url: https://www.anthropic.com/news/rss
    fetch_cadence: weekly
    cache_ttl: 24h
  - id: openai-changelog
    name: OpenAI Changelog
    type: rss
    url: https://openai.com/changelog/rss.xml
    fetch_cadence: weekly
    cache_ttl: 24h
  - id: vercel-blog
    name: Vercel Blog
    type: rss
    url: https://vercel.com/blog/rss.xml
    fetch_cadence: weekly
    cache_ttl: 24h
  - id: supabase-blog
    name: Supabase Blog
    type: rss
    url: https://supabase.com/blog/rss.xml
    fetch_cadence: weekly
    cache_ttl: 24h
  - id: claude-code-releases
    name: Claude Code Release Notes
    type: atom
    url: https://github.com/anthropics/claude-code/releases.atom
    fetch_cadence: weekly
    cache_ttl: 24h
  - id: anthropic-sdk-python-releases
    name: Anthropic SDK Python Releases
    type: atom
    url: https://github.com/anthropics/anthropic-sdk-python/releases.atom
    fetch_cadence: weekly
    cache_ttl: 24h
