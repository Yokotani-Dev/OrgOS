{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orgos.plan_contract.v1",
  "title": "OrgOS Plan Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "title",
    "acceptance",
    "allowed_paths",
    "verification",
    "created_at",
    "created_by"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "orgos.plan_contract.v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^T-OS-[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "expect"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "expect": {
            "type": "string",
            "enum": [
              "pass",
              "fail"
            ]
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "enum": [
        "manager",
        "owner",
        "codex"
      ]
    }
  }
}
