{
  "language": "japanese",
  "permissions": {
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable",
    "additionalDirectories": [
      ".worktrees"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git checkout main:*)",
      "Bash(git checkout master:*)"
    ],
    "allow": [
      "Skill",
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npm run:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)"
    ]
  },
  "sandbox": {
    "enabled": false
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session_start_context.py"
          },
          {
            "type": "command",
            "command": "bash scripts/session/bootstrap.sh 2>/dev/null || echo 'bootstrap skipped'"
          },
          {
            "type": "command",
            "command": "bash scripts/activity/log-event.sh --type session_start --title 'session start' --source hook --stdin-hook 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash scripts/activity/bridge-kernel-events.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/SessionStart.sh || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pretool_policy.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop_gate.py"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session_memory.py end"
          },
          {
            "type": "command",
            "command": "bash scripts/activity/summarize-session.sh --stdin-hook 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
