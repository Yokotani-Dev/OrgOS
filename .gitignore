# OrgOS
.worktrees/
.claude/settings.local.json
.ai/_archive/
.DS_Store
.collaborator

# Safe Memory - secret 混入事故防止
.ai/USER_PROFILE.yaml
.ai/CAPABILITIES.yaml

# GOALS is intentionally tracked. Keep it commit-safe and free of secrets.

# Local-only overrides
.pre-commit-config.local.yaml

# Autonomous run artifacts (v0.23.0)
.ai/CODEX/LOGS/
.ai/BACKUPS/
.ai/AUDIT/
.ai/APPROVALS/
.ai/METRICS/daily-health/
# Two-zone migration (_machine) equivalents — keep old lines above for legacy clones
.ai/_machine/codex/LOGS/
.ai/_machine/backups/
.ai/_machine/approvals/
.ai/_machine/metrics/daily-health/

# Codex output secret hygiene (T-OS-375)
.ai/CODEX/RESULTS/*.log
.ai/_machine/codex/RESULTS/*.log
.claude/state/git.lock
.claude/state/expected_branch_*
.worktrees/

# Git hygiene (audit 2026-06-10 P3#23, P2#10): runtime backups / session state
.ai/TASKS.yaml.bak.*
# Session/policy runtime state — only kernel-mode.json is legitimate tracked config
.claude/state/*
!.claude/state/kernel-mode.json
# Runtime lock artifact (scheduler)
.claude/scheduled_tasks.lock

# Kernel v2 runtime artifact snapshots (collect-artifacts.sh) — durable on disk, not tracked.
# 1.5GB / 57k files of recursive snapshots (snapshots-of-snapshots via files/untracked + files/generated);
# integrator flow already treats these as internal paths excluded from commits (T-OS-423..425).
# Added during ISS-002 backlog integration 2026-06-12 (T-OS-491).
.ai/ARTIFACTS/T-OS-*/
.ai/artifacts/T-OS-*/
.ai/_machine/artifacts/T-OS-*/
# Events ledger runtime lock (hash-chained monthly JSONL files themselves stay tracked)
.ai/events/.events.lock
.ai/_machine/events/.events.lock
# Transient flat lease-event ledger (acquire/release-lease.sh, orgos.event.v1) — runtime, not tracked
.ai/EVENTS.jsonl
